## Core
MARKET_SYMBOL=ETH
CAPITAL_USD=100000
MODEL_PATH=model.joblib
# Hyperliquid candles used for ATR, swing stop, and technical brain (e.g. 15m, 1h).
HYPERLIQUID_CANDLE_INTERVAL=15m
# Minimum stop distance as multiple of 14-bar mean range (ATR proxy).
ATR_STOP_MULT=2.5
# If true, OpenAI may suggest take-profit %; if false, DEFAULT_TAKE_PROFIT_PCT is used (recommended).
USE_AI_TP_SL=false
# If true, OpenAI synthesizes macro bias for scoring; if false, deterministic Vedic/crypto rules only (recommended).
USE_LLM_MACRO_BIAS=false
# Divide Kelly notional by leverage so high leverage does not oversize margin use.
RISK_ADJUST_NOTIONAL_FOR_LEVERAGE=true

## Ephemeris (pyswisseph / Swiss Ephemeris — recommended for production)
# Optional folder with sepl_18.se1 etc.; empty uses built-in Moshier (FLG_MOSEPH) fallback.
SWISSEPH_EPHE_PATH=
# If true, never call Swiss; use built-in Kepler approximation only.
DISABLE_SWISSEPH=false
# Mars–Saturn opposition orb for samasaptaka-style flag (degrees).
SAMASAPTAKA_ORB_DEG=3.0
# Persisted last solar eclipse sidereal degree (for Mars/Saturn transit trigger).
ALMANAC_STATE_PATH=almanac_state.json
ECLIPSE_ALMANAC_REFRESH_DAYS=30
ECLIPSE_TRIGGER_ORB_DEG=1.25
# Mid-trade force-close for longs when heuristics fire (see vedic_signals.py).
ENABLE_PANCHA_VEDHA_EXIT=true
ENABLE_ECLIPSE_DEGREE_EXIT=true

# Optional state/log paths (useful on Railway)
BOT_STATE_PATH=bot_state.json
BOT_JOURNAL_PATH=bot_journal.jsonl

## Safety (highly recommended)
# Dry-run by default. Set LIVE_TRADING=true only when you're ready.
LIVE_TRADING=false
# Hard safety lock: even with LIVE_TRADING=true, bot refuses to place orders unless verified.
HYPERLIQUID_EXECUTION_VERIFIED=false
# If true, disables the astrology “red day” trading halt.
DISABLE_RED_DAY_GATE=false
# If true, allows entries without TP/SL (not recommended).
ALLOW_UNPROTECTED_POSITIONS=false
MAX_NOTIONAL_PCT=0.10
MAX_LEVERAGE=10
# Optional TP/SL defaults (percent of price). Used when AI is unavailable.
DEFAULT_TAKE_PROFIT_PCT=0.5
DEFAULT_STOP_LOSS_PCT=0.3
# Polling/cooldowns (seconds)
# - While a position is open, only check TP/SL closure at this cadence.
ACTIVE_POSITION_CHECK_SECONDS=3600
# - After a position closes, wait this long before the next prediction/entry.
POST_TRADE_COOLDOWN_SECONDS=3600
# - After submitting an order bundle, wait this long to prevent duplicate submits.
ORDER_SUBMIT_COOLDOWN_SECONDS=120

## Hyperliquid (required if LIVE_TRADING=true)
HYPERLIQUID_API_KEY=
HYPERLIQUID_API_SECRET=
HYPERLIQUID_WALLET_ADDRESS=
HYPERLIQUID_API_BASE=https://api.hyperliquid.xyz

## OpenAI (required for AI/context)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
# Cheapest GPT-4-class model (as of 2026): override as needed
OPENAI_API_MODEL=gpt-4.1-mini

## OANDA (optional / unused by default entrypoint)
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice
OANDA_INSTRUMENT=BCO_USD

## Discord alerts (optional)
# Enable alerts
DISCORD_ALERTS_ENABLED=false
# Option A: webhook (simple, posts to a channel)
DISCORD_WEBHOOK_URL=
# Option B: 1:1 DM (requires a bot you created and invited to a server)
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=
# Rate limit to avoid spam
DISCORD_MIN_ALERT_INTERVAL_SECONDS=30

# Discord DM commands + daily reports (optional)
DISCORD_COMMANDS_ENABLED=false
# Some bots require the Message Content intent enabled in the Discord Developer Portal.
DISCORD_MESSAGE_CONTENT_INTENT=true
# Daily PnL report at 8PM America/New_York (EST/EDT)
DISCORD_DAILY_REPORT_ENABLED=false
DISCORD_DAILY_REPORT_HOUR_LOCAL=20

# Stop loss: fractal pivots (preferred) then rolling window low/high
STOP_USE_PIVOTS=true
PIVOT_STOP_LEFT=2
PIVOT_STOP_RIGHT=2
STOP_RECENT_LOOKBACK_CANDLES=24
STOP_RECENT_BUFFER_PCT=0.00
# python main.py calibrate — output JSON path
CALIBRATION_OUT_PATH=calibration_out.json
# Minimum stop distance to avoid ultra-tight stops
MIN_STOP_DISTANCE_PCT=0.50
MIN_STOP_DISTANCE_USD=10.00

# Safety: refuse to trade if placeholder feeds are in use.
# Set true only for local dry-run experiments.
ALLOW_PLACEHOLDER_FEEDS=false

# Vedic entry gates (approximate hora; see ephemeris_engine docstrings)
BLOCK_SATURN_HORA_ENTRIES=true
BLOCK_INAUSPICIOUS_TITHI_ENTRIES=true
# If true, only Jupiter or Mars hora allows new entries (stricter).
REQUIRE_JUPITER_MARS_HORA=false
