## Core
MARKET_SYMBOL=ETH
CAPITAL_USD=100000
MODEL_PATH=model.joblib

## Safety (highly recommended)
LIVE_TRADING=false
HYPERLIQUID_EXECUTION_VERIFIED=false
DISABLE_RED_DAY_GATE=false
ALLOW_UNPROTECTED_POSITIONS=false
MAX_NOTIONAL_PCT=0.10
MAX_LEVERAGE=10

## Hyperliquid (required if LIVE_TRADING=true)
HYPERLIQUID_API_KEY=your_hyperliquid_key_or_agent_id
HYPERLIQUID_API_SECRET=your_api_wallet_private_key
HYPERLIQUID_WALLET_ADDRESS=0xYourEthereumWalletAddress
HYPERLIQUID_API_BASE=https://api.hyperliquid.xyz

## Gemini (required for AI/context)
GEMINI_API_KEY=your_gemini_key
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_MODEL=gemini-2.5-flash

## OANDA (optional / unused by default entrypoint)
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice
OANDA_INSTRUMENT=BCO_USD
